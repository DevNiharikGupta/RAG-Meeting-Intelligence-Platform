OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
CHROMA_DB_PATH=./data/chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50

#Used in place of llama3 due to size same issue in tinyllama model was too small
OLLAMA_LLM_MODEL=phi3
TOP_K=5

# Databricks config (fill these with your workspace details)
DATABRICKS_HOST=xxxxxxx.cloud.databricks.com
DATABRICKS_TOKEN=xxxxxxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxx
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=default
